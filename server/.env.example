# ================================================
# NexRec — API Keys Configuration
# ================================================
# Copy this file to .env and fill in your keys.
#
# FREE API Keys (easy to get):
#
# 1. TMDB (Movies):
#    → Go to: https://www.themoviedb.org/settings/api
#    → Sign up free → request API key → paste below
#
# 2. YouTube Data API v3 (Videos):
#    → Go to: https://console.cloud.google.com/
#    → Create project → Enable "YouTube Data API v3"
#    → Create credentials → API Key → paste below
#
# 3. NewsAPI (News):
#    → Go to: https://newsapi.org/register
#    → Sign up free → copy API key → paste below
#
# NOTE: iTunes API (Music & Podcasts) needs NO KEY — works automatically!
# ================================================

TMDB_API_KEY=your_tmdb_api_key_here
YOUTUBE_API_KEY=your_youtube_api_key_here
NEWS_API_KEY=your_newsapi_key_here
PORT=5000
